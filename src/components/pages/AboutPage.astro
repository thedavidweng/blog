---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { absoluteUrl, siteConfig } from '../../site.config';
import { defaultLocale, type Locale } from '../../lib/locale';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isDefault = locale === defaultLocale;
const title = isDefault ? 'About' : '关于';
const description = isDefault ? `About ${siteConfig.author}.` : `关于 ${siteConfig.author}。`;
const path = isDefault ? '/about/' : `/${locale}/about/`;
const alternatePath = isDefault ? '/zh/about/' : '/about/';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: isDefault ? `About ${siteConfig.author}` : `关于 ${siteConfig.author}`,
  description,
  url: absoluteUrl(path),
  about: {
    '@type': 'Person',
    name: siteConfig.author,
    url: absoluteUrl('/')
  },
  inLanguage: isDefault ? 'en' : 'zh-CN'
};
---

<BaseLayout locale={locale} title={title} description={description} path={path} alternatePath={alternatePath} active="about" jsonLd={jsonLd}>
  <section class="content-wrap">
    <header class="hero">
      <h1>{title}</h1>
      <p class="hero-copy">{siteConfig.role[locale]}</p>
    </header>
    <div class="about-panel">
      {siteConfig.about[locale].map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </section>
</BaseLayout>
