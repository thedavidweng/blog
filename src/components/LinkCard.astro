---
interface Props {
  url: string;
  title: string;
  description?: string;
  image?: string;
  favicon?: string;
  domain?: string;
}

const { url, title, description, image, favicon, domain } = Astro.props;
const displayDomain = domain || new URL(url).hostname;
const displayFavicon = favicon || `https://www.google.com/s2/favicons?domain=${displayDomain}&sz=32`;
---

<div class="not-prose">
  <a href={url} class="rlc-container" target="_blank" rel="noopener noreferrer">
    <div class="rlc-info">
      <div class="rlc-title">{title}</div>
      {description && <div class="rlc-description">{description}</div>}
      <div class="rlc-url-container">
        <img src={displayFavicon} alt="" class="rlc-favicon" />
        <span class="rlc-url">{displayDomain}</span>
      </div>
    </div>
    {image && (
      <div class="rlc-image-container">
        <img src={image} alt={title} class="rlc-image" />
      </div>
    )}
  </a>
</div>

<style>
  /* Use the same styles as the remark-link-card but outside .prose if needed */
  .rlc-container {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    text-decoration: none;
    color: var(--text);
    transition: box-shadow 0.2s var(--ease-out-quart), transform 0.2s var(--ease-out-quart), border-color 0.2s var(--ease-out-quart);
    margin: 2rem 0;
    background: var(--bg);
  }

  .rlc-container:hover {
    box-shadow: var(--shadow);
    transform: translateY(-1px);
    border-color: var(--accent);
  }

  .rlc-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 1rem 1.25rem;
    flex: 1;
    min-width: 0;
  }

  .rlc-title {
    font-weight: 700;
    font-size: 1.05rem;
    line-height: 1.35;
    margin: 0 0 0.4rem 0;
    color: var(--text);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .rlc-description {
    font-size: 0.9rem;
    color: var(--muted);
    margin: 0 0 0.8rem 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.5;
  }

  .rlc-url-container {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: auto;
  }

  .rlc-favicon {
    width: 16px;
    height: 16px;
    margin: 0;
    border-radius: 2px;
  }

  .rlc-url {
    font-size: 0.82rem;
    color: var(--muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-weight: 500;
  }

  .rlc-image-container {
    display: flex;
    background: var(--panel);
  }

  .rlc-image {
    width: 100%;
    height: 180px;
    object-fit: cover;
    margin: 0;
    border-radius: 0;
  }

  @media (min-width: 640px) {
    .rlc-container {
      flex-direction: row;
      height: 130px;
    }
    .rlc-info {
      padding: 1.25rem 1.5rem;
    }
    .rlc-image-container {
      width: 260px;
      flex-shrink: 0;
      border-left: 1px solid var(--border);
    }
    .rlc-image {
      height: 100%;
    }
  }
</style>
