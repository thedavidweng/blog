---
import { render } from 'astro:content';
import PostLayout from '../../../layouts/PostLayout.astro';
import { assertTranslatedPostPairs, postUrl } from '../../../lib/content';

export async function getStaticPaths() {
  const pairs = await assertTranslatedPostPairs();
  return pairs.map(({ slug, posts }) => ({
    params: { slug },
    props: {
      post: posts.en,
      alternatePath: postUrl('zh', slug)
    }
  }));
}

const { post, alternatePath } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(post);
---

<PostLayout post={post} alternatePath={alternatePath} remarkPluginFrontmatter={remarkPluginFrontmatter}>
  <Content />
</PostLayout>
