---
import type { CollectionEntry } from 'astro:content';
import { getPostInfo } from '../lib/content';
import type { Locale } from '../lib/locale';

interface Props {
  locale: Locale;
  posts: Array<CollectionEntry<'posts'>>;
}

const { locale, posts } = Astro.props;

if (posts.length === 0) return null;

const isZh = locale === 'zh';

const items = posts.map((post) => {
  const info = getPostInfo(post);
  return { url: info.url, title: info.title, description: post.data.description };
});
---

<section class="related-posts" aria-label={isZh ? '相关文章' : 'Related posts'}>
  <h2 class="related-posts-heading">{isZh ? '相关文章' : 'Related Posts'}</h2>
  <ul class="related-posts-list">
    {items.map((item) => (
      <li>
        <a href={item.url} class="related-posts-link">
          <span class="related-posts-title">{item.title}</span>
          <span class="related-posts-desc">{item.description}</span>
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  .related-posts {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .related-posts-heading {
    font-size: 1rem;
    font-weight: 600;
    color: var(--muted);
    margin-bottom: 1rem;
  }

  .related-posts-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .related-posts-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    text-decoration: none;
    transition: border-color 0.2s var(--ease-out-quart), background-color 0.2s var(--ease-out-quart);
  }

  .related-posts-link:hover {
    border-color: var(--accent);
    background-color: var(--panel-strong);
  }

  .related-posts-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .related-posts-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.4;
  }

  .related-posts-desc {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
