---
import BaseLayout from '../layouts/BaseLayout.astro';
import { absoluteUrl, siteConfig } from '../site.config';

const locale = 'en';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: `About ${siteConfig.author}`,
  description: `About ${siteConfig.author}.`,
  url: absoluteUrl('/about/'),
  about: {
    '@type': 'Person',
    name: siteConfig.author,
    url: absoluteUrl('/')
  },
  inLanguage: 'en'
};
---

<BaseLayout locale={locale} title="About" description={`About ${siteConfig.author}.`} path="/about/" alternatePath="/zh/about/" active="about" jsonLd={jsonLd}>
  <section class="content-wrap">
    <header class="hero">
      <h1>About</h1>
      <p class="hero-copy">{siteConfig.role[locale]}</p>
    </header>
    <div class="about-panel">
      {siteConfig.about[locale].map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </section>
</BaseLayout>
