<div id="reading-progress-container" class="fixed top-0 left-0 w-full h-1 bg-transparent z-50 pointer-events-none">
  <div id="reading-progress-bar" class="h-full bg-accent w-0 transition-all duration-150 ease-out"></div>
</div>

<script>
  function updateProgress() {
    const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
    const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
    const scrolled = (winScroll / height) * 100;
    const bar = document.getElementById("reading-progress-bar");
    if (bar) {
      bar.style.width = scrolled + "%";
    }
  }

  // Update on scroll
  window.addEventListener('scroll', updateProgress, { passive: true });
  // Initial call
  updateProgress();
</script>
