---
interface Props {
  locale: 'en' | 'zh';
}

const { locale } = Astro.props;
const tocTitle = locale === 'zh' ? '目录' : 'Table of Contents';
---

<!-- tocbot will inject the table of contents here -->
<aside class="toc-wrapper sticky top-32 hidden lg:block min-w-0 w-full">
  <div class="text-xs font-bold mb-4 text-zinc-400 dark:text-zinc-500 tracking-wider uppercase">{tocTitle}</div>
  <nav class="js-toc toc"></nav>
</aside>

<script>
  import tocbot from 'tocbot';

  function initToc() {
    tocbot.destroy();
    tocbot.init({
      tocSelector: '.js-toc',
      contentSelector: '.prose',
      headingSelector: 'h2, h3, h4',
      hasInnerContainers: true,
      scrollSmooth: false,
      activeLinkClass: 'is-active-link',
      listItemClass: 'toc-list-item',
      linkClass: 'toc-link text-sm text-zinc-500 hover:text-accent dark:text-zinc-400 dark:hover:text-accent transition-colors',
      collapseDepth: 6,
      headingsOffset: 86,
      scrollSmoothOffset: -86,
    });
  }

  document.addEventListener('astro:page-load', initToc);
</script>

<style is:global>
  .toc-wrapper {
    max-height: calc(100vh - 10rem);
    overflow-y: auto;
    scrollbar-width: none;
  }
  .toc-wrapper::-webkit-scrollbar {
    display: none;
  }
  .toc-list {
    list-style: none;
    padding-left: 0;
    margin: 0;
  }
  .toc-list .toc-list {
    padding-left: 1.25rem;
  }
  .toc-list-item {
    margin-bottom: 0.5rem;
  }
  .toc-link {
    display: block;
    padding: 0.15rem 0;
    line-height: 1.4;
    position: relative;
    border-left: 2px solid transparent;
    padding-left: 0.75rem;
    margin-left: -2px;
  }
  .is-active-link {
    color: var(--accent) !important;
    font-weight: 600;
    border-left-color: var(--accent);
  }
  .toc-link:hover {
    color: var(--accent);
  }
</style>
