---
import LocaleRedirect from '../LocaleRedirect.astro';
import PostCard from '../PostCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPosts } from '../../lib/content';
import { getHomeJsonLd } from '../../lib/locale-routing';
import { siteConfig } from '../../site.config';
import { defaultLocale, type Locale } from '../../lib/locale';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isDefault = locale === defaultLocale;
const posts = await getPublishedPosts(locale);
const jsonLd = getHomeJsonLd(locale);
const title = isDefault ? 'Blog' : '博客';
const path = isDefault ? '/' : `/${locale}/`;
const alternatePath = isDefault ? '/zh/' : '/';
---

<BaseLayout
  locale={locale}
  title={title}
  description={siteConfig.description[locale]}
  path={path}
  alternatePath={alternatePath}
  active="posts"
  jsonLd={jsonLd}
  includeLocaleRedirect={isDefault}
>
  {isDefault && <LocaleRedirect slot="locale-redirect" />}
  <section class="content-wrap">
    <header class="hero">
      <h1>{title}</h1>
      <p class="hero-copy">{siteConfig.description[locale]}</p>
    </header>
    <div class="post-list">
      {posts.map((post) => <PostCard post={post} locale={locale} />)}
    </div>
  </section>
</BaseLayout>
