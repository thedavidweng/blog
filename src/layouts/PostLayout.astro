---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import { getPostSlug, parsePostId, tagLabel } from '../lib/content';
import { ogImagePath, postUrl, tagUrl } from '../lib/locale';
import { absoluteUrl, defaultLocale, siteConfig } from '../site.config';
import Giscus from '../components/Giscus.astro';
import Toc from '../components/Toc.astro';
import PostNavigation from '../components/PostNavigation.astro';
import RelatedPosts from '../components/RelatedPosts.astro';

interface Props {
  post: CollectionEntry<'posts'>;
  alternatePath: string;
  remarkPluginFrontmatter?: Record<string, any>;
  prev?: CollectionEntry<'posts'>;
  next?: CollectionEntry<'posts'>;
  relatedPosts?: Array<CollectionEntry<'posts'>>;
}

const { post, alternatePath, remarkPluginFrontmatter, prev, next, relatedPosts = [] } = Astro.props;
const { locale } = parsePostId(post.id);
const slug = getPostSlug(post);
const narrowFigures = post.data.narrowFigures === true;
const postPath = postUrl(locale, slug);
const ogPath = ogImagePath(locale, slug);
const date = post.data.publishedDate.toLocaleDateString(locale === 'zh' ? 'zh-CN' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC'
});
const dateLabel = locale === 'zh' ? `发布于 ${date}` : `Published on ${date}`;

const readingTime = remarkPluginFrontmatter?.readingTime;
const readingTimeLabel = readingTime
  ? (locale === 'zh' ? ` · 约 ${Math.ceil(readingTime.minutes)} 分钟阅读` : ` · ${Math.ceil(readingTime.minutes)} min read`)
  : '';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.publishedDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.publishedDate).toISOString(),
  author: {
    '@type': 'Person',
    name: siteConfig.author
  },
  mainEntityOfPage: absoluteUrl(postPath),
  image: absoluteUrl(ogPath),
  inLanguage: locale === defaultLocale ? 'en' : 'zh-CN',
  keywords: post.data.tags.map((tag) => tagLabel(locale, tag))
};
---

<BaseLayout
  locale={locale}
  title={post.data.title}
  description={post.data.description}
  path={postPath}
  alternatePath={alternatePath}
  active="posts"
  image={ogPath}
  type="article"
  jsonLd={jsonLd}
>
  <article class:list={['article', 'relative', 'article--with-toc', narrowFigures && 'article--narrow-figures']}>
    <div class:list={['article-primary', 'min-w-0']}>
    <header class="article-header">
      <p class="post-meta">
        <time datetime={post.data.publishedDate.toISOString()}>{dateLabel}</time>
        <span>{readingTimeLabel}</span>
      </p>
      <h1 class="article-title">{post.data.title}</h1>
      <p class="article-description">{post.data.description}</p>
      <ul class="tag-list" aria-label={locale === 'zh' ? '文章标签' : 'Article tags'}>
        {post.data.tags.map((tag) => <li><a class="tag-pill" href={tagUrl(locale, tag)}>{tagLabel(locale, tag)}</a></li>)}
      </ul>
    </header>
    <div
      class:list={[
        'prose prose-zinc dark:prose-invert mx-auto prose-a:text-accent prose-a:no-underline prose-img:rounded-lg',
        'max-w-none'
      ]}
    >
      <slot />
    </div>

    <div class:list={['max-w-none', 'mx-auto']}>
      <PostNavigation locale={locale} prev={prev} next={next} />
      <RelatedPosts locale={locale} posts={relatedPosts} />
    </div>

    <Giscus slug={slug} locale={locale} />
    </div>
    <Toc locale={locale} />
  </article>

  <script>
    import mediumZoom from 'medium-zoom';

    function initMediumZoom() {
      const images = document.querySelectorAll('.prose img');
      mediumZoom(images, {
        margin: 24,
        background: 'var(--bg)'
      });
    }

    document.addEventListener('astro:page-load', initMediumZoom);
  </script>
</BaseLayout>
