{
  "name": "blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check && pnpm test:source && pnpm test:content && pnpm test:plugins",
    "check:images": "node scripts/check-image-formats.js",
    "test:source": "tsx tests/source-contract.test.ts",
    "test:content": "tsx tests/content-contract.test.ts",
    "test:plugins": "tsx tests/remark-link-card.test.ts",
    "test:dist": "tsx tests/dist-contract.test.ts",
    "convert-images": "tsx scripts/convert-to-avif.mjs",
    "lint": "oxlint --fix",
    "lint:check": "oxlint",
    "format": "oxfmt --write 'src/**/*.{ts,json}' 'tests/**/*.ts' 'scripts/**/*.{ts,mjs}'",
    "format:check": "oxfmt --check 'src/**/*.{ts,json}' 'tests/**/*.ts' 'scripts/**/*.{ts,mjs}'",
    "deploy": "wrangler pages deploy ./dist",
    "test": "tsx tests/source-contract.test.ts && tsx tests/content-contract.test.ts && tsx tests/remark-link-card.test.ts",
    "test:coverage": "c8 --reporter=lcov --reporter=text --src=src pnpm test"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@fortawesome/free-brands-svg-icons": "^7.3.0",
    "@lucide/astro": "^1.18.0",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^6.4.8",
    "astro-expressive-code": "^0.43.1",
    "astro-og-canvas": "^0.11.1",
    "canvaskit-wasm": "0.41.1",
    "he": "^1.2.0",
    "mdast-util-to-string": "^4.0.0",
    "medium-zoom": "^1.1.0",
    "open-graph-scraper": "^6.11.0",
    "probe-image-size": "^7.3.0",
    "reading-time": "^1.5.0",
    "rehype-slug": "^6.0.0",
    "sanitize-filename": "^1.6.4",
    "tailwindcss": "^4.3.2",
    "tocbot": "^4.36.8",
    "turndown": "^7.2.4",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@tailwindcss/typography": "^0.5.20",
    "@types/hast": "3.0.4",
    "@types/he": "^1.2.3",
    "@types/mdast": "4.0.4",
    "@types/probe-image-size": "7.2.5",
    "@types/turndown": "^5.0.6",
    "c8": "^11.0.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "sharp": "^0.35.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "wrangler": "^4.105.0",
    "yaml": "2.9.0",
    "zod": "^4.4.3"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ],
    "overrides": {
      "yaml-language-server>yaml": "2.8.4",
      "yaml": "2.8.4",
      "@ungap/structured-clone": "1.3.1",
      "esbuild": ">=0.28.1",
      "ws": ">=8.21.0"
    }
  }
}
