# Link headers for agent discovery (RFC 8288)
# Homepage - point agents to machine-readable resources
/
  Link: </llms.txt>; rel="describedby"; type="text/plain"; title="LLMs.txt"
  Link: </llms-full.txt>; rel="describedby"; type="text/plain"; title="LLMs Full"
  Link: </robots.txt>; rel="describedby"; type="text/plain"; title="Robots Exclusion"
