{
  "name": "blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check && pnpm test:source && pnpm test:content && pnpm test:plugins && pnpm test:middleware && pnpm test:locale",
    "check:images": "node scripts/check-image-formats.js",
    "test:source": "tsx tests/source-contract.test.ts",
    "test:content": "tsx tests/content-contract.test.ts",
    "test:plugins": "tsx tests/link-card.test.ts",
    "test:middleware": "tsx tests/markdown-response.test.ts",
    "test:locale": "tsx tests/locale.test.ts",
    "test:dist": "tsx tests/dist-contract.test.ts",
    "convert-images": "tsx scripts/convert-to-avif.mjs",
    "lint": "oxlint --fix",
    "lint:check": "oxlint",
    "format": "oxfmt --write 'src/**/*.{ts,json}' 'tests/**/*.ts' 'scripts/**/*.{ts,mjs}'",
    "format:check": "oxfmt --check 'src/**/*.{ts,json}' 'tests/**/*.ts' 'scripts/**/*.{ts,mjs}'",
    "deploy": "wrangler pages deploy ./dist",
    "test": "tsx tests/source-contract.test.ts && tsx tests/content-contract.test.ts && tsx tests/link-card.test.ts && tsx tests/markdown-response.test.ts && tsx tests/locale.test.ts",
    "test:coverage": "c8 --reporter=lcov --reporter=text --src=src pnpm test",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@astrojs/markdown-satteri": "0.3.4",
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@fortawesome/free-brands-svg-icons": "^7.3.1",
    "@lucide/astro": "^1.24.0",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.1.3",
    "astro-expressive-code": "^0.44.0",
    "astro-og-canvas": "^0.13.0",
    "canvaskit-wasm": "0.41.1",
    "medium-zoom": "^1.1.0",
    "open-graph-scraper": "^6.12.0",
    "reading-time": "^1.5.0",
    "satteri": "0.9.5",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2",
    "tocbot": "^4.36.8",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@tailwindcss/typography": "^0.5.20",
    "@types/hast": "3.0.5",
    "@types/mdast": "4.0.4",
    "@types/turndown": "^5.0.6",
    "c8": "^12.0.0",
    "knip": "^6.27.0",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.111.0",
    "yaml": "2.9.0",
    "zod": "^4.4.3"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ],
    "overrides": {
      "yaml-language-server>yaml": "2.8.4",
      "yaml": "2.8.4",
      "@ungap/structured-clone": "1.3.1",
      "esbuild": ">=0.28.1",
      "ws": ">=8.21.0"
    }
  }
}
