---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../site.config';

const locale = 'zh';
---

<BaseLayout locale={locale} title="关于" description={`关于 ${siteConfig.author}。`} path="/zh/about/" alternatePath="/about/" active="about">
  <section class="content-wrap">
    <header class="hero">
      <h1>关于</h1>
      <p class="hero-copy">{siteConfig.role[locale]}</p>
    </header>
    <div class="about-panel">
      <p>{siteConfig.description[locale]}</p>
      <p>这个站点是一个静态 Astro 博客，重点是清晰写作、快速加载和小而稳定的内容工作流。</p>
    </div>
  </section>
</BaseLayout>
