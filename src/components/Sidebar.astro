---
import { BookOpenText, BriefcaseBusiness, House, Info, Languages, Moon, Sun, Tags } from '@lucide/astro';
import BrandIcon from './BrandIcon.astro';
import { defaultLocale, localizedPath, siteConfig, type Locale } from '../site.config';

interface Props {
  locale: Locale;
  active: 'posts' | 'tags' | 'about';
  alternatePath: string;
}

const { locale, active, alternatePath } = Astro.props;
const nav = siteConfig.nav[locale];
const navLandmark = locale === 'zh' ? '主导航' : 'Primary navigation';
const socialLandmark = locale === 'zh' ? '外部链接' : 'External links';
const toolbarLandmark = locale === 'zh' ? '主题与语言' : 'Theme and language';
const themeLabel = locale === 'zh' ? '切换浅色或深色主题' : 'Toggle light or dark theme';
const langLabel = locale === 'zh' ? 'Switch to English' : 'Switch to Chinese';
const social = siteConfig.social;

const links = [
  { key: 'posts', href: localizedPath(locale), label: nav.posts, icon: BookOpenText },
  { key: 'tags', href: localizedPath(locale, '/tags/'), label: nav.tags, icon: Tags },
  { key: 'about', href: localizedPath(locale, '/about/'), label: nav.about, icon: Info }
] as const;

const socialIcons = {
  portfolio: BriefcaseBusiness,
  home: House
};
---

<aside class="site-sidebar" transition:persist="sidebar">
  <div class="sidebar-inner">
    <a class="brand" href={localizedPath(locale)} aria-label={siteConfig.name}>
      <span class="brand-mark">
        <img
          src="/android-chrome-512x512.png"
          alt=""
          width="58"
          height="58"
          decoding="async"
          fetchpriority="low"
        />
      </span>
      <span class="brand-text">
        <span class="brand-name">{siteConfig.author}</span>
        <span class="brand-role">{siteConfig.role[locale]}</span>
      </span>
    </a>

    <div class="sidebar-actions">
      <nav class="site-nav" aria-label={navLandmark}>
        {
          links.map(({ key, href, label, icon: Icon }) => (
            <a class="nav-link" href={href} aria-current={active === key ? 'page' : undefined}>
              <Icon size={23} stroke-width={2.4} />
              <span>{label}</span>
            </a>
          ))
        }
      </nav>

      <nav class="social-nav" aria-label={socialLandmark}>
        {
          social.map((item, index) => (
            <>
              {index === 3 && <hr class="social-divider" aria-hidden="true" />}
              <a class="social-link" href={item.href} rel="me noopener noreferrer" target="_blank">
                {item.icon === 'github' || item.icon === 'linkedin' || item.icon === 'x' ? (
                  <BrandIcon brand={item.icon} size={23} />
                ) : (
                  (() => {
                    const Icon = socialIcons[item.icon];
                    return <Icon size={23} stroke-width={2.3} />;
                  })()
                )}
                <span>{item.label}</span>
              </a>
            </>
          ))
        }
      </nav>
    </div>
  </div>
</aside>

<div class="toolbar" role="group" transition:persist="toolbar" aria-label={toolbarLandmark}>
  <button class="icon-button" type="button" data-theme-toggle aria-label={themeLabel} title={themeLabel}>
    <Sun class="theme-light" size={22} />
    <Moon class="theme-dark" size={22} />
  </button>
  <a class="icon-button" href={alternatePath} hreflang={locale === defaultLocale ? 'zh-CN' : 'en'} aria-label={langLabel} title={langLabel} data-locale-link>
    <Languages size={22} />
  </a>
</div>

<script is:inline define:vars={{ i18n: { nav: siteConfig.nav, role: siteConfig.role } }}>
  function updateActiveNav() {
    const current = location.pathname.replace(/\/+$/, '') || '/';
    document.querySelectorAll('.nav-link').forEach((link) => {
      const href = link instanceof HTMLAnchorElement ? new URL(link.href).pathname.replace(/\/+$/, '') || '/' : '';
      if (href === current) {
        link.setAttribute('aria-current', 'page');
      } else {
        link.removeAttribute('aria-current');
      }
    });
  }

  function getLocale() {
    return location.pathname.startsWith('/zh') ? 'zh' : 'en';
  }

  function updateLocaleContent() {
    const locale = getLocale();
    const altLocale = locale === 'zh' ? 'en' : 'zh';

    // nav link labels & hrefs
    const navKeys = ['posts', 'tags', 'about'];
    document.querySelectorAll('.nav-link').forEach((link, i) => {
      const key = navKeys[i];
      const label = link.querySelector('span');
      if (label) label.textContent = i18n.nav[locale][key];
      if (link instanceof HTMLAnchorElement) {
        const base = locale === 'en' ? '/' : '/zh/';
        const suffix = key === 'posts' ? '' : `${key}/`;
        link.href = base === '/' && suffix === '' ? '/' : `${base}${suffix}`;
      }
    });

    // brand role & link
    const roleEl = document.querySelector('.brand-role');
    if (roleEl) roleEl.textContent = i18n.role[locale];
    const brandLink = document.querySelector('.brand');
    if (brandLink instanceof HTMLAnchorElement) brandLink.href = locale === 'en' ? '/' : '/zh/';

    // toolbar locale link
    const localeLink = document.querySelector('[data-locale-link]');
    if (localeLink instanceof HTMLAnchorElement) {
      localeLink.href = altLocale === 'zh' ? '/zh/' : '/';
      localeLink.hreflang = altLocale === 'zh' ? 'zh-CN' : 'en';
      localeLink.setAttribute('aria-label', locale === 'zh' ? 'Switch to English' : 'Switch to Chinese');
      localeLink.title = localeLink.getAttribute('aria-label') ?? '';
    }

    // toolbar aria
    const toolbar = document.querySelector('.toolbar');
    if (toolbar) toolbar.setAttribute('aria-label', locale === 'zh' ? '主题与语言' : 'Theme and language');
    const themeBtn = document.querySelector('[data-theme-toggle]');
    if (themeBtn) {
      const label = locale === 'zh' ? '切换浅色或深色主题' : 'Toggle light or dark theme';
      themeBtn.setAttribute('aria-label', label);
      themeBtn.title = label;
    }

    // nav landmarks
    const siteNav = document.querySelector('.site-nav');
    if (siteNav) siteNav.setAttribute('aria-label', locale === 'zh' ? '主导航' : 'Primary navigation');
    const socialNav = document.querySelector('.social-nav');
    if (socialNav) socialNav.setAttribute('aria-label', locale === 'zh' ? '外部链接' : 'External links');

    // skip link
    const skipLink = document.querySelector('.skip-link');
    if (skipLink) skipLink.textContent = locale === 'zh' ? '跳到正文' : 'Skip to content';
  }

  document.addEventListener('astro:after-swap', () => {
    updateActiveNav();
    updateLocaleContent();
  });

  const root = document.documentElement;
  const themeButton = document.querySelector('[data-theme-toggle]');
  themeButton?.addEventListener('click', () => {
    const nextTheme = root.dataset.theme === 'dark' ? 'light' : 'dark';
    root.dataset.theme = nextTheme;
    try {
      localStorage.setItem('theme', nextTheme);
    } catch {
      /* ignore */
    }
  });

  document.querySelector('[data-locale-link]')?.addEventListener('click', (event) => {
    const href = event.currentTarget instanceof HTMLAnchorElement ? event.currentTarget.getAttribute('href') : null;
    try {
      localStorage.setItem('preferred-locale', href?.startsWith('/zh') ? 'zh' : 'en');
    } catch {
      /* ignore */
    }
  });
</script>

<style>
  :root[data-theme="dark"] .theme-light,
  :root:not([data-theme="dark"]) .theme-dark {
    display: none;
  }
</style>
