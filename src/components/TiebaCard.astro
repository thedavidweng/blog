---
import LinkCard from './LinkCard.astro';

interface Props {
  url: string;
  title: string;
  description?: string;
  image?: string;
}

const { url, title, description, image } = Astro.props;
---

<LinkCard
  url={url}
  title={title}
  description={description}
  image={image}
  domain="tieba.baidu.com"
  favicon="https://tb1.bdstatic.com/tb/favicon.ico"
/>
