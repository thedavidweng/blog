---
import { ChevronUp } from '@lucide/astro';

interface Props {
  locale: 'en' | 'zh';
}

const { locale } = Astro.props;
const label = locale === 'zh' ? '回到顶部' : 'Back to top';
---

<button type="button" class="back-to-top icon-button" data-back-to-top aria-label={label}>
  <ChevronUp size={22} stroke-width={2.25} aria-hidden="true" />
</button>

<script is:inline>
  (function() {
    let scrollHandler;
    const btn = document.querySelector('[data-back-to-top]');
    if (!btn) return;

    function setup() {
      if (scrollHandler) window.removeEventListener('scroll', scrollHandler);

      const threshold = 360;

      scrollHandler = () => {
        btn.classList.toggle('back-to-top--visible', window.scrollY > threshold);
      };

      scrollHandler();
      window.addEventListener('scroll', scrollHandler, { passive: true });
    }

    btn.addEventListener('click', () => {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      window.scrollTo({ top: 0, behavior: reduce ? 'auto' : 'smooth' });
    });

    document.addEventListener('astro:page-load', setup);
    setup();
  })();
</script>
