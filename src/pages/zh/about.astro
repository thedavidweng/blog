---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { absoluteUrl, siteConfig } from '../../site.config';

const locale = 'zh';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: `关于 ${siteConfig.author}`,
  description: `关于 ${siteConfig.author}。`,
  url: absoluteUrl('/zh/about/'),
  about: {
    '@type': 'Person',
    name: siteConfig.author,
    url: absoluteUrl('/')
  },
  inLanguage: 'zh-CN'
};
---

<BaseLayout locale={locale} title="关于" description={`关于 ${siteConfig.author}。`} path="/zh/about/" alternatePath="/about/" active="about" jsonLd={jsonLd}>
  <section class="content-wrap">
    <header class="hero">
      <h1>关于</h1>
      <p class="hero-copy">{siteConfig.role[locale]}</p>
    </header>
    <div class="about-panel">
      {siteConfig.about[locale].map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </section>
</BaseLayout>
