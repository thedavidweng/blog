---
---

<!-- tocbot will inject the table of contents here -->
<div class="toc-wrapper hidden lg:block absolute top-0 left-full ml-10 w-64 h-full z-10">
  <div class="sticky top-32">
    <div class="text-xs font-bold mb-4 text-zinc-400 dark:text-zinc-500 tracking-wider uppercase">Table of Contents</div>
    <nav class="js-toc toc"></nav>
  </div>
</div>

<script>
  import tocbot from 'tocbot';

  // Initialize tocbot
  tocbot.init({
    // Where to render the table of contents.
    tocSelector: '.js-toc',
    // Where to grab the headings to build the table of contents.
    contentSelector: '.prose',
    // Which headings to grab inside of the contentSelector element.
    headingSelector: 'h2, h3, h4',
    // For headings inside relative or absolute positioned containers within content.
    hasInnerContainers: true,
    // Smooth scroll
    scrollSmooth: true,
    scrollSmoothDuration: 420,
    // Class added to active links
    activeLinkClass: 'is-active-link',
    // Class added to list items
    listItemClass: 'toc-list-item',
    // Class added to links
    linkClass: 'toc-link text-sm text-zinc-500 hover:text-accent dark:text-zinc-400 dark:hover:text-accent transition-colors',
    // Collapse deeper levels
    collapseDepth: 6,
    // Headings offset for sticky headers/padding
    headingsOffset: 86,
    scrollSmoothOffset: -86,
  });
</script>

<style is:global>
  .toc-wrapper {
    max-height: calc(100vh - 10rem);
    overflow-y: auto;
    scrollbar-width: none;
  }
  .toc-wrapper::-webkit-scrollbar {
    display: none;
  }
  .toc-list {
    list-style: none;
    padding-left: 0;
    margin: 0;
  }
  .toc-list .toc-list {
    padding-left: 1.25rem;
  }
  .toc-list-item {
    margin-bottom: 0.5rem;
  }
  .toc-link {
    display: block;
    padding: 0.15rem 0;
    line-height: 1.4;
    position: relative;
    border-left: 2px solid transparent;
    padding-left: 0.75rem;
    margin-left: -2px;
  }
  .is-active-link {
    color: var(--accent) !important;
    font-weight: 600;
    border-left-color: var(--accent);
  }
  .toc-link:hover {
    color: var(--accent);
  }
</style>
