---
import { faGithub, faLinkedin, faXTwitter } from '@fortawesome/free-brands-svg-icons';

type BrandName = 'github' | 'linkedin' | 'x';

interface Props {
  brand: BrandName;
  size?: number;
}

const { brand, size = 23 } = Astro.props;
const icons = {
  github: faGithub,
  linkedin: faLinkedin,
  x: faXTwitter
};
const icon = icons[brand];
const [width, height, , , path] = icon.icon;
---

<svg width={size} height={size} viewBox={`0 0 ${width} ${height}`} aria-hidden="true" fill="currentColor">
  <path d={Array.isArray(path) ? path.join(' ') : path} />
</svg>
