<script is:inline>
  (() => {
    const key = 'theme';
    function applyTheme() {
      try {
        let stored = null;
        try {
          stored = localStorage.getItem(key);
        } catch {
          /* storage unavailable (private mode, blocked, quota) */
        }
        let prefersDark = false;
        try {
          prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        } catch {
          /* matchMedia unsupported */
        }
        const valid = stored === 'light' || stored === 'dark';
        const theme = valid ? stored : prefersDark ? 'dark' : 'light';
        document.documentElement.dataset.theme = theme;
      } catch {
        document.documentElement.dataset.theme = 'dark';
      }
    }
    applyTheme();
    // ClientRouter replaces <html> on navigation; re-apply after swap
    document.addEventListener('astro:after-swap', applyTheme);
  })();
</script>
