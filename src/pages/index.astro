---
import LocaleRedirect from '../components/LocaleRedirect.astro';
import PostCard from '../components/PostCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublishedPosts } from '../lib/content';
import { getHomeJsonLd } from '../lib/locale-routing';
import { siteConfig } from '../site.config';

const locale = 'en';
const posts = await getPublishedPosts(locale);
const jsonLd = getHomeJsonLd(locale);
---

<BaseLayout
  locale={locale}
  title="Blog"
  description={siteConfig.description[locale]}
  path="/"
  alternatePath="/zh/"
  active="posts"
  jsonLd={jsonLd}
  includeLocaleRedirect
>
  <LocaleRedirect slot="locale-redirect" />
  <section class="content-wrap">
    <header class="hero">
      <h1>Blog</h1>
      <p class="hero-copy">{siteConfig.description[locale]}</p>
    </header>
    <div class="post-list">
      {posts.map((post) => <PostCard post={post} locale={locale} />)}
    </div>
  </section>
</BaseLayout>
