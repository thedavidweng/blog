---
import LocaleRedirect from '../components/LocaleRedirect.astro';
import PostCard from '../components/PostCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublishedPosts } from '../lib/content';
import { absoluteUrl, siteConfig } from '../site.config';

const locale = 'en';
const posts = await getPublishedPosts(locale);
const siteUrl = absoluteUrl('/');
const socialUrls = siteConfig.social
  .filter(s => ['GitHub', 'LinkedIn', 'X'].includes(s.label))
  .map(s => s.href);
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Blog',
      name: siteConfig.name,
      description: siteConfig.description[locale],
      url: siteUrl,
      author: {
        '@type': 'Person',
        name: siteConfig.author,
        jobTitle: 'Developer and Designer',
        knowsAbout: ['Open-source tools', 'Desktop application development', 'AI-integrated creative work']
      },
      inLanguage: 'en'
    },
    {
      '@type': 'Organization',
      name: siteConfig.name,
      url: siteUrl,
      logo: absoluteUrl('/android-chrome-512x512.png'),
      sameAs: socialUrls
    },
    {
      '@type': 'Person',
      name: siteConfig.author,
      url: siteUrl,
      sameAs: socialUrls,
      jobTitle: 'Developer and Designer',
      knowsAbout: ['Open-source tools', 'Desktop application development', 'AI-integrated creative work']
    },
    {
      '@type': 'WebSite',
      name: siteConfig.name,
      url: siteUrl
    }
  ]
};
---

<BaseLayout
  locale={locale}
  title="Blog"
  description={siteConfig.description[locale]}
  path="/"
  alternatePath="/zh/"
  active="posts"
  jsonLd={jsonLd}
  includeLocaleRedirect
>
  <LocaleRedirect slot="locale-redirect" />
  <section class="content-wrap">
    <header class="hero">
      <h1>Blog</h1>
      <p class="hero-copy">{siteConfig.description[locale]}</p>
    </header>
    <div class="post-list">
      {posts.map((post) => <PostCard post={post} locale={locale} />)}
    </div>
  </section>
</BaseLayout>
